---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'StatGate — Cổng tính toán thống kê thống nhất',
  description = 'Trung tâm toàn diện cho Stata, R, SPSS và PLS-SEM. Hướng dẫn, cú pháp, gói lệnh và kiến thức cộng đồng.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#0a0a0a] min-h-screen text-white overflow-x-hidden">

    <!-- ═══ llmgate.app BACKGROUND LAYERS ═══ -->
    <!-- Layer 1: Solid dark base -->
    <div class="fixed inset-0 bg-[#0a0a0a] -z-50" aria-hidden="true"></div>

    <!-- Layer 2: Subtle grid pattern (exactly like llmgate) -->
    <div
      class="fixed inset-0 pointer-events-none -z-40"
      style="background-image: linear-gradient(rgba(249,115,22,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(249,115,22,0.04) 1px, transparent 1px); background-size: 64px 64px;"
      aria-hidden="true"
    ></div>

    <!-- Layer 3: Radial glow top-center (orange, like llmgate hero glow) -->
    <div
      class="fixed top-0 left-1/2 -translate-x-1/2 w-[85vw] h-[55vh] rounded-full pointer-events-none -z-30"
      style="background: radial-gradient(ellipse at center, rgba(249,115,22,0.10) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <!-- Layer 4: Soft bottom-left glow -->
    <div
      class="fixed bottom-0 left-[-10%] w-[50vw] h-[40vh] rounded-full pointer-events-none -z-30"
      style="background: radial-gradient(ellipse at center, rgba(249,115,22,0.06) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <!-- Layer 5: Subtle top-left ambient -->
    <div
      class="fixed top-[20%] right-[5%] w-[30vw] h-[30vh] rounded-full pointer-events-none -z-30"
      style="background: radial-gradient(ellipse at center, rgba(249,115,22,0.04) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <!-- ═══ NAVBAR ═══ -->
    <header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
      <nav class="relative mx-auto max-w-5xl px-4 sm:px-6 mt-4">
        <div
          class="flex items-center justify-between rounded-2xl border border-[#2a2a2a] bg-[#111111]/90 backdrop-blur-2xl px-5 py-3 transition-all duration-300"
        >
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2.5 group flex-shrink-0">
            <div
              class="flex h-8 w-8 items-center justify-center rounded-lg border border-orange-500/40 bg-orange-500/10 shadow-[0_0_14px_rgba(249,115,22,0.3)]"
            >
              <svg
                class="h-4 w-4 text-orange-400"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
              </svg>
            </div>
            <span class="text-base font-semibold tracking-tight text-white font-['Space_Grotesk']">
              Stat<span class="text-orange-400">Gate</span>
            </span>
          </a>

          <!-- Desktop Nav Links -->
          <div class="hidden md:flex items-center gap-1">
            <a
              href="#"
              class="px-4 py-1.5 text-sm text-[#a1a1a1] hover:text-white rounded-lg hover:bg-white/5 transition-all duration-200"
            >
              Hướng dẫn
            </a>
            <a
              href="#"
              class="px-4 py-1.5 text-sm text-[#a1a1a1] hover:text-white rounded-lg hover:bg-white/5 transition-all duration-200"
            >
              Gói lệnh
            </a>
            <a
              href="#"
              class="px-4 py-1.5 text-sm text-[#a1a1a1] hover:text-white rounded-lg hover:bg-white/5 transition-all duration-200"
            >
              Cộng đồng
            </a>
            <a
              href="https://github.com"
              target="_blank"
              rel="noopener noreferrer"
              class="ml-2 px-4 py-1.5 text-sm font-medium text-orange-400 bg-orange-500/10 border border-orange-500/30 rounded-lg hover:bg-orange-500/20 hover:border-orange-400/50 transition-all duration-200"
            >
              GitHub
            </a>
          </div>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden flex h-8 w-8 items-center justify-center rounded-lg border border-[#2a2a2a] text-[#a1a1a1] hover:text-white hover:border-[#3a3a3a] transition-all duration-200"
            aria-label="Mở menu"
          >
            <svg id="menu-icon" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div
          id="mobile-menu"
          class="hidden md:hidden mt-2 rounded-xl border border-[#2a2a2a] bg-[#111111]/95 backdrop-blur-xl px-4 py-3 shadow-xl"
        >
          <div class="flex flex-col gap-1">
            <a href="#" class="px-3 py-2 text-sm text-[#a1a1a1] hover:text-white hover:bg-white/5 rounded-lg transition-all">Hướng dẫn</a>
            <a href="#" class="px-3 py-2 text-sm text-[#a1a1a1] hover:text-white hover:bg-white/5 rounded-lg transition-all">Gói lệnh</a>
            <a href="#" class="px-3 py-2 text-sm text-[#a1a1a1] hover:text-white hover:bg-white/5 rounded-lg transition-all">Cộng đồng</a>
            <div class="border-t border-[#2a2a2a] mt-2 pt-2">
              <a href="#" class="px-3 py-2 text-sm font-medium text-orange-400 hover:text-orange-300 rounded-lg transition-all">GitHub</a>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <!-- ═══ PAGE CONTENT ═══ -->
    <main class="relative z-10 pt-24 pb-16 px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto">
      <slot />
    </main>

    <!-- ═══ FOOTER ═══ -->
    <footer class="relative z-10 border-t border-[#1a1a1a] mt-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-[#666666]">
            &copy; 2026 StatGate. Xây dựng cho cộng đồng nghiên cứu.
          </p>
          <div class="flex items-center gap-6">
            <a href="#" class="text-xs text-[#666666] hover:text-[#a1a1a1] transition-colors">Tài liệu</a>
            <a href="#" class="text-xs text-[#666666] hover:text-[#a1a1a1] transition-colors">GitHub</a>
            <a href="#" class="text-xs text-[#666666] hover:text-[#a1a1a1] transition-colors">Discord</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- ═══ NAVBAR SCRIPTS ═══ -->
    <script>
      const navbar = document.getElementById('navbar') as HTMLElement;
      const mobileMenuBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement;
      const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
      let menuOpen = false;

      window.addEventListener('scroll', () => {
        if (window.scrollY > 20) {
          navbar.classList.add('bg-[#0a0a0a]/90', 'backdrop-blur-xl', 'shadow-[0_4px_24px_rgba(0,0,0,0.5)]');
          (navbar.querySelector('nav > div') as HTMLElement)?.classList.add('border-[#333333]');
          (navbar.querySelector('nav > div') as HTMLElement)?.classList.remove('border-[#2a2a2a]');
        } else {
          navbar.classList.remove('bg-[#0a0a0a]/90', 'backdrop-blur-xl', 'shadow-[0_4px_24px_rgba(0,0,0,0.5)]');
          (navbar.querySelector('nav > div') as HTMLElement)?.classList.remove('border-[#333333]');
          (navbar.querySelector('nav > div') as HTMLElement)?.classList.add('border-[#2a2a2a]');
        }
      }, { passive: true });

      mobileMenuBtn.addEventListener('click', () => {
        menuOpen = !menuOpen;
        mobileMenu.classList.toggle('hidden', !menuOpen);
      });
    </script>
  </body>
</html>
