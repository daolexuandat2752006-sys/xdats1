---
import Layout from '../layouts/Layout.astro';

// ─── TABS CONFIG ───────────────────────────────────────────────────────────────
const tabs = [
  { id: 'stata',   label: 'Stata',    color: 'orange',  icon: 'S',  desc: 'Phần mềm chuyên về kinh tế lượng & phân tích dữ liệu' },
  { id: 'r',       label: 'R',        color: 'amber',   icon: 'R',  desc: 'Ngôn ngữ cho tính toán & đồ họa thống kê' },
  { id: 'spss',    label: 'SPSS',     color: 'yellow',  icon: 'SP', desc: 'Nền tảng phân tích thống kê của IBM' },
  { id: 'pls',     label: 'PLS-SEM',  color: 'lime',    icon: 'PL', desc: 'Mô hình phương trình cấu trúc bán tham số' },
];

// ─── CONTENT DATA ──────────────────────────────────────────────────────────────
const tabContent: Record<string, {
  sections: Array<{
    id: string;
    title: string;
    titleEn?: string;
    icon: string;
    description: string;
    tags: string[];
