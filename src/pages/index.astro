  { label: 'Mẫu quá nhỏ (n < 10× số chỉ tiêu của khối lớn nhất)', severity: 'Tới hạn' },
  { label: 'Bootstrap < 5000 mà không báo cáo', severity: 'Trung bình' },
  { label: 'Bỏ qua đánh giá dự báo (PLSpredict / Q²)', severity: 'Nghiêm trọng' },
];
---

<Layout>
  <!-- ═══════════════════════════════════════════
       HERO
  ════════════════════════════════════════════ -->
  <section class="text-center max-w-4xl mx-auto mb-10">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-orange-500/20 bg-orange-500/5 text-orange-300 text-xs font-mono font-medium mb-5">
      <span class="relative flex h-1.5 w-1.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-orange-500"></span>
      </span>
      v2.0 — 11 danh mục · 46+ lệnh · 12 so sánh
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold font-['Space_Grotesk'] tracking-tight mb-5 leading-[1.1]">
      <span class="text-white">Cổng tính toán</span><br />
      <span class="bg-gradient-to-r from-orange-400 via-amber-400 to-orange-400 bg-clip-text text-transparent">Thống kê & Kinh tế lượng</span><br />
      <span class="text-white">Thống nhất</span>
    </h1>

    <p class="text-sm sm:text-base text-[#a1a1a1] max-w-2xl mx-auto leading-relaxed mb-7">
      Hướng dẫn thực hành tập trung vào <span class="text-white font-medium">Stata</span>,
      <span class="text-white font-medium">R</span>,
      <span class="text-white font-medium">SPSS</span> và
      <span class="text-white font-medium">PLS-SEM</span>.
      Nên dùng lệnh nào? Hiểu sự đánh đổi — điều hướng tự tin.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="#explore"
        class="group inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-orange-500 hover:bg-orange-400 text-white text-sm font-semibold shadow-[0_0_24px_rgba(249,115,22,0.35)] hover:shadow-[0_0_36px_rgba(249,115,22,0.5)] transition-all duration-300">
        Khám phá ngay
        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
      <a href="https://github.com"
        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl border border-[#2a2a2a] bg-[#111111] hover:bg-[#1a1a1a] text-[#a1a1a1] hover:text-white text-sm font-medium transition-all duration-200">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TABS
  ════════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto mb-10">
    <div id="explore"
      class="relative flex flex-wrap items-center justify-center gap-1 sm:gap-2 p-1.5 rounded-xl border border-[#2a2a2a] bg-[#111111]/60 backdrop-blur-xl shadow-inner"
      style="scroll-margin-top: 5rem;">
      <div id="tab-indicator"
        class="absolute top-1.5 bottom-1.5 rounded-lg transition-all duration-300 ease-out"
        style="width: calc(25% - 6px); left: 3px; background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.25); box-shadow: 0 0 20px rgba(249,115,22,0.15);">
      </div>
      {tabs.map((tab, i) => (
        <button data-tab={tab.id} data-index={i}
          class="relative z-10 flex-1 min-w-[100px] flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 whitespace-nowrap cursor-pointer"
          aria-selected={i === 0 ? 'true' : 'false'}>
          <span class={`tab-icon-${tab.id} inline-flex items-center justify-center h-5 w-5 rounded text-[10px] font-bold font-mono transition-all duration-200 ${i === 0 ? `bg-${tab.color}-500/20 text-${tab.color}-300` : 'bg-white/5 text-[#666]'}`}>
            {tab.icon}
          </span>
          <span class={`tab-label-${tab.id} ${i === 0 ? 'text-white' : 'text-[#a1a1a1]'}`}>{tab.label}</span>
        </button>
      ))}
    </div>
    <div class="mt-3 text-center">
      <p id="tab-description" class="text-xs text-[#666]">{tabs[0].desc}</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TAB PANELS
  ════════════════════════════════════════════ -->
  <div id="tab-panels" class="max-w-5xl mx-auto">

    <!-- ─── STATA ─── -->
    <div id="panel-stata" class="tab-panel" data-panel="stata">

      <!-- Quick Start Paths -->
      <section class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-[#666] uppercase tracking-widest font-['Space_Grotesk']">Bắt đầu tại đây</h2>
          <span class="text-xs text-[#666] hover:text-orange-400 cursor-pointer transition-colors">Dùng cây quyết định →</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Beginner Path -->
          <div class="rounded-2xl border border-[#2a2a2a] bg-[#111111]/60 backdrop-blur-xl p-5">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-base">🎓</span>
              <h3 class="text-sm font-semibold text-white">Lộ trình người mới</h3>
            </div>
            <div class="space-y-1.5">
              {stataPathBeginner.map((item) => (
                <div class="flex items-center gap-3 rounded-lg px-3 py-2 hover:bg-white/5 transition-colors cursor-default group">
                  <span class="flex-shrink-0 w-5 h-5 rounded-full border border-[#333] bg-[#0a0a0a] flex items-center justify-center text-[10px] font-mono font-bold text-[#666] group-hover:border-orange-500/40 group-hover:text-orange-400 transition-colors">
                    {item.step}
                  </span>
                  <span class="text-xs text-[#a1a1a1] group-hover:text-white transition-colors">{item.label}</span>
                </div>
              ))}
            </div>
          </div>
          <!-- Research Path -->
          <div class="rounded-2xl border border-[#2a2a2a] bg-[#111111]/60 backdrop-blur-xl p-5">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-base">🔬</span>
              <h3 class="text-sm font-semibold text-white">Lộ trình nghiên cứu</h3>
            </div>
            <div class="space-y-1.5">
              {stataPathResearch.map((item) => (
                <div class="flex items-center gap-3 rounded-lg px-3 py-2 hover:bg-white/5 transition-colors cursor-default group">
                  <svg class="h-3 w-3 text-[#444] group-hover:text-orange-400 flex-shrink-0 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                  </svg>
                  <span class="text-xs text-[#a1a1a1] group-hover:text-white transition-colors">{item.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Category Cards Grid -->
      <section class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-[#666] uppercase tracking-widest font-['Space_Grotesk']">11 Danh mục kinh tế lượng</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {stataCategories.map((cat) => (
            <div class="group relative flex flex-col rounded-xl border border-[#2a2a2a] bg-[#111111]/60 hover:bg-[#161616]/80 backdrop-blur-xl p-4 cursor-pointer transition-all duration-200 hover:border-orange-500/30 hover:shadow-[0_0_30px_rgba(249,115,22,0.08)] hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#2a2a2a] bg-[#0a0a0a] text-[#666] group-hover:text-orange-400 group-hover:border-orange-500/30 group-hover:bg-orange-500/5 transition-all duration-200">
                  <div class="h-4 w-4" set:html={cat.icon} />
                </div>
                <div class="flex items-center gap-2 flex-wrap justify-end">
                  <span class={`px-2 py-0.5 rounded text-[10px] font-mono font-medium border ${cat.levelColor}`}>{cat.level}</span>
                </div>
              </div>
              <h3 class="text-sm font-semibold text-white mb-1 leading-tight">{cat.name}</h3>
              <p class="text-xs text-[#666] leading-relaxed flex-1 mb-3">{cat.desc}</p>
              <div class="border-t border-[#2a2a2a] pt-2.5">
                <div class="text-[10px] font-mono text-[#555]">{cat.count} · {cat.detail}</div>
              </div>
              <div class="absolute bottom-0 left-4 right-4 h-px bg-gradient-to-r from-transparent via-orange-500/0 to-transparent group-hover:via-orange-500/40 transition-all duration-300"></div>
            </div>
          ))}
        </div>
      </section>

      <!-- Best Packages Table -->
      <section class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-[#666] uppercase tracking-widest font-['Space_Grotesk']">Gói tốt nhất theo trường hợp sử dụng</h2>
        </div>
        <div class="rounded-xl border border-[#2a2a2a] bg-[#111111]/60 backdrop-blur-xl overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-xs">
              <thead>
                <tr class="border-b border-[#2a2a2a]">
                  <th class="text-left px-4 py-3 text-[#555] font-semibold uppercase tracking-wider">Trường hợp</th>
                  <th class="text-left px-4 py-3 text-[#555] font-semibold uppercase tracking-wider">Lệnh / Gói</th>
                  <th class="text-left px-4 py-3 text-[#555] font-semibold uppercase tracking-wider hidden sm:table-cell">Cấp độ</th>
                  <th class="text-left px-4 py-3 text-[#555] font-semibold uppercase tracking-wider hidden md:table-cell">Ghi chú</th>
                </tr>
              </thead>
              <tbody>
                {stataBestPackages.map((pkg, i) => (
                  <tr class={`border-b border-[#1e1e1e] ${i % 2 === 0 ? '' : 'bg-white/[0.01]'}`}>
                    <td class="px-4 py-3 text-[#a1a1a1]">{pkg.use}</td>
                    <td class="px-4 py-3">
                      <code class="px-1.5 py-0.5 rounded bg-orange-500/10 text-orange-300 border border-orange-500/20 text-[11px] font-mono font-medium">
                        {pkg.cmd}
                      </code>
                    </td>
                    <td class="px-4 py-3 hidden sm:table-cell">
                      <span class={`px-2 py-0.5 rounded text-[10px] font-mono font-medium border ${
                        pkg.level === 'Cơ bản' ? 'bg-green-500/10 text-green-300 border-green-500/20' :
                        pkg.level === 'Trung cấp' ? 'bg-yellow-500/10 text-yellow-300 border-yellow-500/20' :
                        'bg-red-500/10 text-red-300 border-red-500/20'
                      }`}>{pkg.level}</span>
                    </td>
                    <td class="px-4 py-3 text-[#555] hidden md:table-cell">{pkg.note}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- Comparisons Pills -->
      <section class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-[#666] uppercase tracking-widest font-['Space_Grotesk']">So sánh quan trọng nhất</h2>
          <span class="text-xs text-[#666] hover:text-orange-400 cursor-pointer transition-colors">Tất cả so sánh →</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {stataComparisons.map((comp) => (
            <button class="px-3 py-1.5 rounded-lg border border-[#2a2a2a] bg-[#111111]/60 text-xs text-[#a1a1a1] hover:text-orange-400 hover:border-orange-500/30 hover:bg-orange-500/5 transition-all duration-200 font-mono">
              {comp}
            </button>
          ))}
        </div>
      </section>

      <!-- Critical Evaluation -->
      <section class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-[#666] uppercase tracking-widest font-['Space_Grotesk']">Đánh giá phê phán</h2>
          <span class="text-xs text-[#666] hover:text-orange-400 cursor-pointer transition-colors">Sai lầm phổ biến →</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {stataWarnings.map((w) => (
            <div class={`rounded-xl border px-4 py-3 ${
              w.type === 'danger'  ? 'border-red-500/20 bg-red-500/5' :
              w.type === 'warning' ? 'border-yellow-500/20 bg-yellow-500/5' :
              'border-green-500/20 bg-green-500/5'
            }`}>
              <div class={`text-xs font-semibold mb-1.5 ${
                w.type === 'danger'  ? 'text-red-400' :
                w.type === 'warning' ? 'text-yellow-400' :
                'text-green-400'
              }`}>{w.title}</div>
              <p class="text-xs text-[#a1a1a1] leading-relaxed">{w.body}</p>
            </div>
          ))}
        </div>
      </section>
    </div>

    <!-- ─── R ─── -->
    <div id="panel-r" class="tab-panel hidden" data-panel="r">
      <section class="mb-8">
        <div class="flex items-center gap-2 mb-1">
          <div class="text-base">📦</div>
          <h2 class="text-base font-semibold text-white">Gói lệnh tốt nhất trong R</h2>
        </div>
        <p class="text-xs text-[#666] mb-5">Hệ sinh thái tidyverse là nền tảng — các gói chuyên biệt cho từng phương pháp.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2.5">
          {rPackages.map((pkg) => (
            <div class="group flex items-start gap-3 rounded-xl border border-[#2a2a2a] bg-[#111111]/60 hover:bg-[#161616]/80 px-4 py-3 transition-all duration-200 hover:-translate-y-0.5 cursor-default">
              <svg class="h-3 w-3 text-[#444] group-hover:text-amber-400 flex-shrink-0 mt-0.5 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
              <div class="min-w-0 flex-1">
                <div class="text-sm text-[#e0e0e0] group-hover:text-white font-medium leading-tight mb-1 transition-colors">{pkg.label}</div>
                <div class="text-[10px] font-mono px-2 py-0.5 rounded bg-amber-500/10 text-amber-300 border border-amber-500/20 mb-1 inline-block">{pkg.tag}</div>
                <div class="text-[11px] text-[#555] leading-relaxed">{pkg.note}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <div class="flex items-center gap-2 mb-4">
          <div class="text-base">⚠️</div>
          <h2 class="text-base font-semibold text-white">Sai lầm phổ biến trong R</h2>
        </div>
        <div class="space-y-2">
          {rMistakes.map((m) => (
            <div class="flex items-start gap-3 rounded-xl border border-[#2a2a2a] bg-[#111111]/40 px-4 py-3 hover:border-[#333] transition-all duration-200">
              <span class={`flex-shrink-0 h-1.5 w-1.5 rounded-full mt-1.5 ${
                m.severity === 'Nghiêm trọng' ? 'bg-red-500' :
                m.severity === 'Trung bình' ? 'bg-yellow-400' :
                'bg-blue-400'
              }`}></span>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-[#a1a1a1] leading-relaxed">{m.label}</div>
              </div>
              <span class={`flex-shrink-0 text-[10px] font-mono px-2 py-0.5 rounded border ${
                m.severity === 'Nghiêm trọng' ? 'bg-red-500/10 text-red-300 border-red-500/20' :
                m.severity === 'Trung bình' ? 'bg-yellow-500/10 text-yellow-300 border-yellow-500/20' :
                'bg-green-500/10 text-green-300 border-green-500/20'
              }`}>{m.severity}</span>
            </div>
          ))}
        </div>
      </section>
    </div>

    <!-- ─── SPSS ─── -->
    <div id="panel-spss" class="tab-panel hidden" data-panel="spss">
      <section class="mb-8">
        <div class="flex items-center gap-2 mb-1">
          <div class="text-base">📊</div>
          <h2 class="text-base font-semibold text-white">Thủ tục tốt nhất trong SPSS</h2>
        </div>
        <p class="text-xs text-[#666] mb-5">SPSS Syntax chuẩn cho các phương pháp phổ biến trong nghiên cứu xã hội và kinh tế.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
          {spssProcedures.map((proc) => (
            <div class="group flex items-start gap-3 rounded-xl border border-[#2a2a2a] bg-[#111111]/60 hover:bg-[#161616]/80 px-4 py-3 transition-all duration-200 hover:-translate-y-0.5 cursor-default">
              <svg class="h-3 w-3 text-[#444] group-hover:text-yellow-400 flex-shrink-0 mt-0.5 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
              <div class="min-w-0 flex-1">
                <div class="text-sm text-[#e0e0e0] group-hover:text-white font-mono font-medium leading-tight mb-1 transition-colors">{proc.label}</div>
                <div class="text-[10px] font-mono px-2 py-0.5 rounded bg-yellow-500/10 text-yellow-300 border border-yellow-500/20 mb-1 inline-block">{proc.tag}</div>
                <div class="text-[11px] text-[#555] leading-relaxed">{proc.note}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <div class="flex items-center gap-2 mb-4">
          <div class="text-base">⚠️</div>
          <h2 class="text-base font-semibold text-white">Sai lầm phổ biến trong SPSS</h2>
        </div>
        <div class="space-y-2">
          {spssMistakes.map((m) => (
            <div class="flex items-start gap-3 rounded-xl border border-[#2a2a2a] bg-[#111111]/40 px-4 py-3 hover:border-[#333] transition-all duration-200">
              <span class={`flex-shrink-0 h-1.5 w-1.5 rounded-full mt-1.5 ${
                m.severity === 'Nghiêm trọng' ? 'bg-red-500' :
                'bg-yellow-400'
              }`}></span>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-[#a1a1a1] leading-relaxed">{m.label}</div>
              </div>
              <span class={`flex-shrink-0 text-[10px] font-mono px-2 py-0.5 rounded border ${
                m.severity === 'Nghiêm trọng' ? 'bg-red-500/10 text-red-300 border-red-500/20' :
                'bg-yellow-500/10 text-yellow-300 border-yellow-500/20'
              }`}>{m.severity}</span>
            </div>
          ))}
        </div>
      </section>
    </div>

    <!-- ─── PLS-SEM ─── -->
    <div id="panel-pls" class="tab-panel hidden" data-panel="pls">
      <section class="mb-8">
        <div class="flex items-center gap-2 mb-1">
          <div class="text-base">🔬</div>
          <h2 class="text-base font-semibold text-white">Phần mềm & Gói tốt nhất cho PLS-SEM</h2>
        </div>
        <p class="text-xs text-[#666] mb-5">Tiêu chuẩn ngành cho mô hình phương trình cấu trúc bán tham số (PLS-SEM).</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2.5">
          {plsSoftware.map((s) => (
            <div class="group flex items-start gap-3 rounded-xl border border-[#2a2a2a] bg-[#111111]/60 hover:bg-[#161616]/80 px-4 py-3 transition-all duration-200 hover:-translate-y-0.5 cursor-default">
              <svg class="h-3 w-3 text-[#444] group-hover:text-lime-400 flex-shrink-0 mt-0.5 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
              <div class="min-w-0 flex-1">
                <div class="text-sm text-[#e0e0e0] group-hover:text-white font-medium leading-tight mb-1 transition-colors">{s.label}</div>
                <div class="text-[10px] font-mono px-2 py-0.5 rounded bg-lime-500/10 text-lime-300 border border-lime-500/20 mb-1 inline-block">{s.tag}</div>
                <div class="text-[11px] text-[#555] leading-relaxed">{s.note}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <div class="flex items-center gap-2 mb-4">
          <div class="text-base">⚠️</div>
          <h2 class="text-base font-semibold text-white">Sai lầm phổ biến trong PLS-SEM</h2>
        </div>
        <div class="space-y-2">
          {plsMistakes.map((m) => (
            <div class="flex items-start gap-3 rounded-xl border border-[#2a2a2a] bg-[#111111]/40 px-4 py-3 hover:border-[#333] transition-all duration-200">
              <span class={`flex-shrink-0 h-1.5 w-1.5 rounded-full mt-1.5 ${
                m.severity === 'Tới hạn' ? 'bg-red-600' :
                m.severity === 'Nghiêm trọng' ? 'bg-red-500' :
                'bg-yellow-400'
              }`}></span>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-[#a1a1a1] leading-relaxed">{m.label}</div>
              </div>
              <span class={`flex-shrink-0 text-[10px] font-mono px-2 py-0.5 rounded border ${
                m.severity === 'Tới hạn' ? 'bg-red-600/10 text-red-400 border-red-600/20' :
                m.severity === 'Nghiêm trọng' ? 'bg-red-500/10 text-red-300 border-red-500/20' :
                'bg-yellow-500/10 text-yellow-300 border-yellow-500/20'
              }`}>{m.severity}</span>
            </div>
          ))}
        </div>
      </section>
    </div>

  </div><!-- #tab-panels -->

  <!-- Stats Bar -->
  <section class="max-w-5xl mx-auto mt-4 mb-8">
    <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-16 py-8 border-t border-[#1a1a1a]">
      {[
        { value: '4', label: 'Nền tảng phần mềm' },
        { value: '11', label: 'Danh mục Stata' },
        { value: '46+', label: 'Lệnh & gói chuẩn' },
        { value: '12', label: 'Trang so sánh' },
      ].map((s) => (
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold font-['Space_Grotesk'] bg-gradient-to-r from-orange-400 to-amber-400 bg-clip-text text-transparent">{s.value}</div>
          <div class="text-[10px] text-[#555] mt-1 uppercase tracking-wider">{s.label}</div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<!-- ═══════════════════════════════════════════
     TAB SWITCHER SCRIPT
═══════════════════════════════════════════ -->
<script define:vars={{ tabs, colorMap, colorSchemes, positions }}>
  const indicator    = document.getElementById('tab-indicator');
  const descriptionEl = document.getElementById('tab-description');
  const tabButtons   = document.querySelectorAll('[data-tab]');
  const panels       = document.querySelectorAll('.tab-panel');

  function setTab(index) {
    const scheme = colorMap[colorSchemes[index]];

    // Indicator
    if (indicator) {
      indicator.style.left      = positions[index];
      indicator.style.background  = scheme.indicatorBg;
      indicator.style.border     = `1px solid ${scheme.indicatorBorder}`;
      indicator.style.boxShadow  = scheme.indicatorShadow;
    }

    // Buttons
    tabButtons.forEach((btn, i) => {
      const isActive = i === index;
      const color    = colorSchemes[i];
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
      const icon = btn.querySelector(`[class*="tab-icon-"]`);
      if (icon) {
        icon.className = `tab-icon-${tabs[i].id} inline-flex items-center justify-center h-5 w-5 rounded text-[10px] font-bold font-mono transition-all duration-200 ${isActive ? `bg-${color}-500/20 text-${color}-300` : 'bg-white/5 text-[#666]'}`;
      }
      const label = btn.querySelector(`[class*="tab-label-"]`);
      if (label) label.className = `tab-label-${tabs[i].id} ${isActive ? 'text-white' : 'text-[#a1a1a1]'}`;
    });

    // Description
    if (descriptionEl) descriptionEl.textContent = tabs[index].desc;

    // Panels with fade
    panels.forEach((panel) => {
      const isTarget = panel.getAttribute('data-panel') === tabs[index].id;
      if (isTarget) {
        panel.classList.remove('hidden');
        panel.style.opacity = '0';
        panel.style.transform = 'translateY(6px)';
        panel.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            panel.style.opacity   = '1';
            panel.style.transform = 'translateY(0)';
          });
        });
      } else {
        panel.classList.add('hidden');
      }
    });
  }

  tabButtons.forEach((btn, i) => {
    btn.addEventListener('click', () => setTab(i));
  });

  tabButtons.forEach((btn, i) => {
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); setTab((i + 1) % tabs.length); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); setTab((i - 1 + tabs.length) % tabs.length); }
    });
  });

  setTab(0);
</script>
