<!-- ═══════════════════════════════════════════════════════════════
     TAB SWITCHER + LANGUAGE SCRIPT
══════════════════════════════════════════════════════════════ -->
<script define:vars={{ tabs, colorSchemes, positions }}>
  const indicator  = document.getElementById('tab-indicator');
  const tabButtons = document.querySelectorAll('[data-tab]');
  const panels     = document.querySelectorAll('.tab-panel');
  const dots       = document.querySelectorAll('[data-dot]');
  const tabCards   = document.querySelectorAll('.tab-card');
  const tabDesc    = document.getElementById('tab-description');
  const langEn     = document.getElementById('lang-en');
  const langVi     = document.getElementById('lang-vi');

  const schemeMap = {
    orange: { bg: 'rgba(249,115,22,0.15)', border: 'rgba(249,115,22,0.30)', shadow: '0 0 16px rgba(249,115,22,0.2)' },
    amber:  { bg: 'rgba(245,158,11,0.15)', border: 'rgba(245,158,11,0.30)', shadow: '0 0 16px rgba(245,158,11,0.2)' },
    yellow: { bg: 'rgba(234,179,8,0.15)',  border: 'rgba(234,179,8,0.30)',  shadow: '0 0 16px rgba(234,179,8,0.2)' },
    lime:   { bg: 'rgba(132,204,22,0.15)', border: 'rgba(132,204,22,0.30)', shadow: '0 0 16px rgba(132,204,22,0.2)' },
  };

  function setTab(index) {
    const color  = colorSchemes[index];
    const scheme = schemeMap[color];

    if (indicator) {
      indicator.style.left      = positions[index];
      indicator.style.background = scheme.bg;
      indicator.style.border   = `1px solid ${scheme.border}`;
      indicator.style.boxShadow = scheme.shadow;
    }

    tabButtons.forEach((btn, i) => {
      const isActive = i === index;
      const c = colorSchemes[i];
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
      const icon  = btn.querySelector(`[class*="tab-icon-"]`);
      const label = btn.querySelector(`[class*="tab-label-"]`);
      if (icon) {
        icon.className = `tab-icon-${tabs[i].id} inline-flex h-5 w-5 items-center justify-center rounded text-[10px] font-bold font-mono transition-all duration-200 ${isActive ? `bg-${c}-500/20 text-${c}-300` : 'bg-white/5 text-[#666]'}`;
      }
      if (label) {
        label.className = `tab-label-${tabs[i].id} ${isActive ? 'text-white' : 'text-[#a1a1a1]'}`;
      }
    });

    dots.forEach((dot, i) => {
      dot.className = `h-2.5 w-2.5 rounded-full transition-colors ${i === index ? 'bg-orange-400' : 'bg-[#555]/60 hover:bg-[#777]'} cursor-pointer`;
    });

    // Switch right-side tab cards
    tabCards.forEach((card) => {
      const isTarget = card.id === `card-${tabs[index].id}`;
      if (isTarget) {
        card.classList.remove('hidden');
        card.style.opacity = '0';
        card.style.transform = 'translateY(8px)';
        card.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          });
        });
      } else {
        card.classList.add('hidden');
      }
    });

    // Switch tab-panel sections
    panels.forEach((panel) => {
      const isTarget = panel.getAttribute('data-panel') === tabs[index].id;
      if (isTarget) {
        panel.classList.remove('hidden');
        panel.style.opacity   = '0';
        panel.style.transform = 'translateY(6px)';
        panel.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            panel.style.opacity   = '1';
            panel.style.transform = 'translateY(0)';
          });
        });
      } else {
        panel.classList.add('hidden');
      }
    });
  }

  tabButtons.forEach((btn, i) => {
    btn.addEventListener('click', () => setTab(i));
  });

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => setTab(i));
  });

  // Keyboard navigation
  tabButtons.forEach((btn, i) => {
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); setTab((i + 1) % tabs.length); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); setTab((i - 1 + tabs.length) % tabs.length); }
    });
  });

  // Language toggle
  if (langEn && langVi) {
    langEn.addEventListener('click', () => {
      langEn.className = 'flex items-center gap-1.5 rounded-md bg-orange-500 text-white px-3 py-1.5 text-sm font-medium min-w-28 justify-center cursor-pointer transition-all duration-200 hover:bg-orange-400';
      langVi.className = 'flex items-center gap-1.5 rounded-md px-3 py-1.5 text-sm font-medium text-[#666] min-w-28 justify-center cursor-pointer transition-all duration-200 hover:bg-[#1a1a1a] hover:text-[#a1a1a1]';
    });
    langVi.addEventListener('click', () => {
      langVi.className = 'flex items-center gap-1.5 rounded-md bg-orange-500 text-white px-3 py-1.5 text-sm font-medium min-w-28 justify-center cursor-pointer transition-all duration-200 hover:bg-orange-400';
      langEn.className = 'flex items-center gap-1.5 rounded-md px-3 py-1.5 text-sm font-medium text-[#666] min-w-28 justify-center cursor-pointer transition-all duration-200 hover:bg-[#1a1a1a] hover:text-[#a1a1a1]';
    });
  }

  setTab(0);
</script>
