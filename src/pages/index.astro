          { label: 'Mẫu quá nhỏ cho PLS-SEM (Hair et al. 2019: n ≥ 10×số chỉ tiêu)', severity: 'Tới hạn', tagColor: 'bg-red-500/10 text-red-300 border-red-500/20' },
