// ─── COLOR MAP FOR TABS ───────────────────────────────────────────────────────
const colorMap: Record<string, {
  indicatorBg: string;
  indicatorBorder: string;
  indicatorShadow: string;
  badge: string;
  badgeText: string;
  glow: string;
  cardBorder: string;
  cardHover: string;
  icon: string;
  iconHover: string;
  rgb: string;
}> = {
  orange:  { indicatorBg: 'rgba(249,115,22,0.12)',  indicatorBorder: 'rgba(249,115,22,0.25)',  indicatorShadow: '0 0 20px rgba(249,115,22,0.15)',  badge: 'bg-orange-500/10 text-orange-300 border-orange-500/20',   badgeText: 'text-orange-300', glow: 'shadow-[0_0_40px_rgba(249,115,22,0.12)]',   cardBorder: 'hover:border-orange-500/30',   cardHover: 'hover:shadow-[0_0_40px_rgba(249,115,22,0.12)]',   icon: 'text-orange-400 group-hover:text-orange-300 border-orange-500/30 group-hover:bg-orange-500/10', iconHover: 'border-orange-500/30 bg-orange-500/10 text-orange-300', rgb: '249,115,22' },
  amber:   { indicatorBg: 'rgba(245,158,11,0.12)',  indicatorBorder: 'rgba(245,158,11,0.25)',  indicatorShadow: '0 0 20px rgba(245,158,11,0.15)',  badge: 'bg-amber-500/10 text-amber-300 border-amber-500/20',   badgeText: 'text-amber-300', glow: 'shadow-[0_0_40px_rgba(245,158,11,0.12)]',   cardBorder: 'hover:border-amber-500/30',   cardHover: 'hover:shadow-[0_0_40px_rgba(245,158,11,0.12)]',   icon: 'text-amber-400 group-hover:text-amber-300 border-amber-500/30 group-hover:bg-amber-500/10', iconHover: 'border-amber-500/30 bg-amber-500/10 text-amber-300', rgb: '245,158,11' },
  yellow:  { indicatorBg: 'rgba(234,179,8,0.12)',   indicatorBorder: 'rgba(234,179,8,0.25)',   indicatorShadow: '0 0 20px rgba(234,179,8,0.15)',   badge: 'bg-yellow-500/10 text-yellow-300 border-yellow-500/20',  badgeText: 'text-yellow-300', glow: 'shadow-[0_0_40px_rgba(234,179,8,0.12)]',   cardBorder: 'hover:border-yellow-500/30',  cardHover: 'hover:shadow-[0_0_40px_rgba(234,179,8,0.12)]',   icon: 'text-yellow-400 group-hover:text-yellow-300 border-yellow-500/30 group-hover:bg-yellow-500/10', iconHover: 'border-yellow-500/30 bg-yellow-500/10 text-yellow-300', rgb: '234,179,8' },
  lime:    { indicatorBg: 'rgba(132,204,22,0.12)',   indicatorBorder: 'rgba(132,204,22,0.25)',  indicatorShadow: '0 0 20px rgba(132,204,22,0.15)',  badge: 'bg-lime-500/10 text-lime-300 border-lime-500/20',    badgeText: 'text-lime-300', glow: 'shadow-[0_0_40px_rgba(132,204,22,0.12)]',   cardBorder: 'hover:border-lime-500/30',    cardHover: 'hover:shadow-[0_0_40px_rgba(132,204,22,0.12)]',   icon: 'text-lime-400 group-hover:text-lime-300 border-lime-500/30 group-hover:bg-lime-500/10', iconHover: 'border-lime-500/30 bg-lime-500/10 text-lime-300', rgb: '132,204,22' },
};

const colorSchemes = ['orange', 'amber', 'yellow', 'lime'];
const positions    = ['3px', 'calc(25% + 3px)', 'calc(50% + 3px)', 'calc(75% + 3px)'];
---

<Layout>
  <!-- ═══════════════════════════════════════════
       HERO SECTION
  ════════════════════════════════════════════ -->
  <section class="text-center max-w-4xl mx-auto mb-12">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-orange-500/20 bg-orange-500/5 text-orange-300 text-xs font-mono font-medium mb-6">
      <span class="relative flex h-1.5 w-1.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-blue-500"></span>
      </span>
      v2.0 — Hướng dẫn Kinh tế lượng & Thống kê
    </div>

    <!-- Heading -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold font-['Space_Grotesk'] tracking-tight mb-6 leading-[1.1]">
      <span class="text-white">Cổng thông tin</span>
      <br />
      <span class="bg-gradient-to-r from-orange-400 via-amber-400 to-orange-400 bg-clip-text text-transparent">
        Tính toán Thống kê
      </span>
      <br />
      <span class="text-white">Thống nhất</span>
    </h1>

    <!-- Subheading -->
    <p class="text-base sm:text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed mb-8">
      Một trung tâm cho hướng dẫn, cú pháp, hệ sinh thái gói lệnh và kiến thức cộng đồng
      về <span class="text-slate-300 font-medium">Stata</span>,
      <span class="text-slate-300 font-medium">R</span>,
      <span class="text-slate-300 font-medium">SPSS</span> và
      <span class="text-slate-300 font-medium">PLS-SEM</span>.
      Xây dựng cho những ai đòi hỏi sự chính xác.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="#explore"
        class="group inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-orange-500 hover:bg-orange-400 text-white text-sm font-semibold shadow-[0_0_24px_rgba(249,115,22,0.35)] hover:shadow-[0_0_36px_rgba(249,115,22,0.5)] transition-all duration-300"
      >
        Khám phá ngay
        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
      <a
        href="#"
        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl border border-slate-700/60 bg-white/5 hover:bg-white/10 text-slate-300 hover:text-white text-sm font-medium transition-all duration-200"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
        </svg>
        GitHub
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TABS SECTION
  ════════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto mb-10">
    <div
      id="explore"
      class="relative flex flex-wrap items-center justify-center gap-1 sm:gap-2 p-1.5 rounded-xl border border-slate-800/80 bg-[#0d1117]/60 backdrop-blur-xl shadow-inner"
      style="scroll-margin-top: 6rem;"
    >
      <!-- Active tab indicator (sliding pill) -->
      <div
        id="tab-indicator"
        class="absolute top-1.5 bottom-1.5 rounded-lg transition-all duration-300 ease-out"
        style="width: calc(25% - 6px); left: 3px; background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.25); box-shadow: 0 0 20px rgba(249,115,22,0.15);"
      ></div>

      {tabs.map((tab, i) => (
        <button
          data-tab={tab.id}
          data-index={i}
          class="relative z-10 flex-1 min-w-[100px] flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 whitespace-nowrap cursor-pointer"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          <span
            class={`tab-icon-${tab.id} inline-flex items-center justify-center h-5 w-5 rounded text-[10px] font-bold font-mono transition-all duration-200 ${
              i === 0 ? `bg-${tab.color}-500/20 text-${tab.color}-300` : 'bg-white/5 text-slate-500'
            }`}
          >
            {tab.icon}
          </span>
          <span class={`tab-label-${tab.id} ${i === 0 ? 'text-white' : 'text-slate-400'}`}>
            {tab.label}
          </span>
        </button>
      ))}
    </div>

    <!-- Tab Description -->
    <div class="mt-4 text-center">
      <p id="tab-description" class="text-sm text-slate-400">
        {tabs[0].desc}
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CONTENT SECTIONS (one panel per tab)
  ════════════════════════════════════════════ -->
  <div id="tab-panels" class="max-w-5xl mx-auto">

    {tabs.map((tab, tabIdx) => {
      const content = tabContent[tab.id];
      const scheme  = colorMap[tab.color];

      return (
        <div
          id={`panel-${tab.id}`}
          class={`tab-panel ${tabIdx === 0 ? '' : 'hidden'}`}
          data-panel={tab.id}
        >
          {content.sections.map((section) => (
            <div class="mb-10">
              <!-- Section header -->
              <div class="flex items-center gap-4 mb-6">
                <div class={`flex h-10 w-10 items-center justify-center rounded-xl border border-slate-700/50 bg-slate-800/40 text-slate-400 flex-shrink-0`}
                  set:html={section.icon}
                />
                <div class="min-w-0">
                  <h2 class="text-base sm:text-lg font-semibold text-white font-['Space_Grotesk'] leading-tight">
                    {section.title}
                    {section.titleEn && (
                      <span class="ml-2 text-xs font-mono text-slate-500 hidden sm:inline">({section.titleEn})</span>
                    )}
                  </h2>
                  <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">{section.description}</p>
                </div>
                <!-- Stats -->
                <div class="hidden sm:flex items-center gap-3 ml-auto flex-shrink-0">
                  {section.stats.map((stat) => (
                    <div class="text-right">
                      <div class={`text-lg font-bold font-['Space_Grotesk'] ${scheme.badgeText}`}>{stat.value}</div>
                      <div class="text-[10px] text-slate-600 uppercase tracking-wider">{stat.label}</div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Tags row -->
              <div class="flex flex-wrap gap-1.5 mb-4">
                {section.tags.map((tag) => (
                  <span class={`px-2.5 py-0.5 rounded-full border text-[10px] font-mono font-medium ${scheme.badge}`}>
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Items grid -->
              <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-2.5">
                {section.items.map((item) => (
                  <div class="group flex items-center gap-3 rounded-xl border border-slate-800/60 bg-[#0d1117]/50 hover:bg-[#0d1117]/80 hover:border-slate-700/80 px-4 py-3 cursor-default transition-all duration-200 hover:-translate-y-0.5">
                    <!-- Severity dot or colored dot -->
                    {item.severity ? (
                      <span class={`flex-shrink-0 h-1.5 w-1.5 rounded-full mt-0.5 ${
                        item.severity === 'Tới hạn'   ? 'bg-red-500' :
                        item.severity === 'Nghiêm trọng' ? 'bg-orange-400' :
                        item.severity === 'Trung bình'  ? 'bg-yellow-400' :
                        item.severity === 'Cơ bản'     ? 'bg-blue-400' :
                        'bg-emerald-400'
                      }`}></span>
                    ) : (
                      <svg class="h-3.5 w-3.5 text-slate-600 group-hover:text-slate-400 flex-shrink-0 transition-colors duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"/>
                      </svg>
                    )}

                    <div class="min-w-0 flex-1">
                      <div class="text-sm text-slate-300 group-hover:text-white transition-colors duration-200 leading-tight truncate">
                        {item.label}
                      </div>
                      {item.tag && (
                        <div class={`mt-1 inline-flex items-center px-2 py-0.5 rounded text-[10px] font-mono border ${item.tagColor || scheme.badge}`}>
                          {item.severity ? item.severity : item.tag}
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}

          <!-- Divider -->
          <div class="border-t border-slate-800/40 mb-8"></div>
        </div>
      );
    })}
  </div>

  <!-- ═══════════════════════════════════════════
       STATS BAR
  ════════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto mt-6 mb-8">
    <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-16 py-8 border-t border-slate-800/40">
      {[
        { value: '4', label: 'Nền tảng phần mềm' },
        { value: '580+', label: 'Hướng dẫn & Bài viết' },
        { value: '12k+', label: 'Thành viên cộng đồng' },
        { value: '98%', label: 'Độ khả dụng SLA' },
      ].map((stat) => (
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold font-['Space_Grotesk'] bg-gradient-to-r from-orange-400 to-amber-400 bg-clip-text text-transparent">
            {stat.value}
          </div>
          <div class="text-xs text-slate-500 mt-1 uppercase tracking-wider">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<!-- ═══════════════════════════════════════════
     TAB SWITCHER + SCROLL SCRIPT
═══════════════════════════════════════════ -->
<script define:vars={{ tabs, colorMap, colorSchemes, positions }}>
  const indicator    = document.getElementById('tab-indicator');
  const descriptionEl = document.getElementById('tab-description');
  const tabButtons   = document.querySelectorAll('[data-tab]');
  const panels       = document.querySelectorAll('.tab-panel');

  // ── Set active tab ──────────────────────────────
  function setTab(index) {
    const color = colorSchemes[index];
    const scheme = colorMap[color];

    // 1) Move sliding indicator
    if (indicator) {
      indicator.style.left      = positions[index];
      indicator.style.background  = scheme.indicatorBg;
      indicator.style.border     = `1px solid ${scheme.indicatorBorder}`;
      indicator.style.boxShadow  = scheme.indicatorShadow;
    }

    // 2) Update button states
    tabButtons.forEach((btn, i) => {
      const isActive = i === index;
      const btnColor = colorSchemes[i];

      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');

      // Icon pill
      const icon = btn.querySelector(`[class*="tab-icon-"]`);
      if (icon) {
        icon.className = `tab-icon-${tabs[i].id} inline-flex items-center justify-center h-5 w-5 rounded text-[10px] font-bold font-mono transition-all duration-200 ${
          isActive
            ? `bg-${btnColor}-500/20 text-${btnColor}-300`
            : 'bg-white/5 text-slate-500'
        }`;
      }

      // Label
      const label = btn.querySelector(`[class*="tab-label-"]`);
      if (label) {
        label.className = `tab-label-${tabs[i].id} ${isActive ? 'text-white' : 'text-slate-400'}`;
      }
    });

    // 3) Update description
    if (descriptionEl) {
      descriptionEl.textContent = tabs[index].desc;
    }

    // 4) Switch panels — fade in
    panels.forEach((panel) => {
      const panelId = panel.getAttribute('data-panel');
      const isTarget = panelId === tabs[index].id;

      if (isTarget) {
        panel.classList.remove('hidden');
        panel.style.opacity    = '0';
        panel.style.transform  = 'translateY(8px)';
        panel.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            panel.style.opacity   = '1';
            panel.style.transform = 'translateY(0)';
          });
        });
      } else {
        panel.classList.add('hidden');
      }
    });

    // 5) Update section icon + card colors per tab color
    document.querySelectorAll('.tab-panel:not(.hidden)').forEach(() => {
      // Update severity dot colors (already handled by CSS classes)
    });
  }

  // ── Attach click handlers ───────────────────────
  tabButtons.forEach((btn, i) => {
    btn.addEventListener('click', () => setTab(i));
  });

  // ── Keyboard navigation ─────────────────────────
  tabButtons.forEach((btn, i) => {
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); setTab((i + 1) % tabs.length); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); setTab((i - 1 + tabs.length) % tabs.length); }
    });
  });

  // ── Initialize ─────────────────────────────────
  setTab(0);
</script>
