---
import Layout from '../layouts/Layout.astro';
import categoriesData from '../../../STATA/assets-20260402T183209Z-1-001/assets/js/data/categories.json';
import commandsData  from '../../../STATA/assets-20260402T183209Z-1-001/assets/js/data/commands.json';

const tabs = [
  { id: 'stata', label: 'Stata',    color: 'orange', icon: 'S',  desc: 'Phần mềm kinh tế lượng — từ OLS cơ bản đến Double ML' },
  { id: 'r',     label: 'R',         color: 'amber',  icon: 'R',  desc: 'Ngôn ngữ & hệ sinh thái thống kê mã nguồn mở' },
  { id: 'spss',  label: 'SPSS',      color: 'yellow', icon: 'SP', desc: 'Nền tảng phân tích thống kê của IBM' },
  { id: 'pls',   label: 'PLS-SEM',   color: 'lime',   icon: 'PL', desc: 'Mô hình phương trình cấu trúc bán tham số' },
];

const colorSchemes = ['orange', 'amber', 'yellow', 'lime'];
const positions    = ['3px', 'calc(25% + 3px)', 'calc(50% + 3px)', 'calc(75% + 3px)'];

// ─── STATA DATA ────────────────────────────────────────────────────────────────
// Computed from source JSON
const sourceCategories = categoriesData.categories;
const allCommands     = commandsData.commands;

// Map difficulty: beginner→Cơ bản, intermediate→Trung cấp, advanced→Nâng cao
const levelMap: Record<string, string> = {
  beginner: 'Cơ bản', intermediate: 'Trung cấp', advanced: 'Nâng cao',
};

const stataCategories = sourceCategories.map((cat: typeof sourceCategories[0]) => {
  const cmdCount  = cat.commands.length;
  const level     = levelMap['intermediate'] ?? 'Trung cấp'; // infer from category
  // Re-infer level from category id patterns
  const basicRe   = /^(ols-diagnostics|data-infrastructure)$/;
  const midRe     = /^(limited-dependent|panel-data|time-series|causal-inference|publication-standards)$/;
  const advRe      = /^(iv-endogeneity|staggered-did|ml-econometrics|sensitivity-robustness)$/;
  let   levelOut  = 'Trung cấp';
  if      (basicRe.test(cat.id)) levelOut = 'Cơ bản';
  else if (midRe.test(cat.id))   levelOut = 'Trung cấp';
  else if (advRe.test(cat.id))   levelOut = 'Nâng cao';

  return {
    id:       cat.id,
    name:     cat.name,
    icon:     cat.icon,
    level:    levelOut,
    count:    `${cmdCount} lệnh`,
    detail:   cat.commands.slice(0, 5).join(' · ') + (cmdCount > 5 ? '…' : ''),
    overview: cat.overview,
    commonMistakes: cat.common_mistakes ?? [],
    upgradePath: cat.upgrade_path ?? '',
    recommendedOrder: cat.recommended_learning_order ?? [],
  };
});

// Build best packages from commands data + enriched with category context
const pkgRows: Array<{ use: string; cmd: string; level: string; note: string }> = [];
sourceCategories.forEach((cat: typeof sourceCategories[0]) => {
  const cmds = cat.commands;
  if (cmds.length === 0) return;
  const firstCmd = cmds[0];
  const cmdObj   = allCommands.find((c: typeof allCommands[0]) => c.id === firstCmd);
  if (!cmdObj) return;
  const diff = levelMap[cmdObj.difficulty ?? 'intermediate'] ?? 'Trung cấp';
  // Build a summary note from recommended_learning_order
  const firstStep = (cat.recommended_learning_order ?? [])[0];
  const note = firstStep ? firstStep.reason : (cmdObj.content?.what_it_does ?? '').slice(0, 80);
  pkgRows.push({ use: cat.name, cmd: cmds.slice(0, 3).join(' · '), level: diff, note });
});

const stataBestPackages = pkgRows.slice(0, 10);
const totalCmdCount = allCommands.length;

const stataPathBeginner = [
  'reg — Hồi quy OLS',
  'robust — Luôn dùng SE vững',
  'logit + margins — Biến nhị phân',
  'xtreg, fe — Dữ liệu bảng',
  'diff — Đánh giá chính sách (DID)',
  'estout — Bảng kết quả công bố',
];

const stataPathResearch = [
  'ivreg2 — Ước lượng IV',
  'reghdfe — FE chiều cao',
  'csdid — DID theo giai đoạn',
  'boottest — Suy luận ít nhóm',
  'honestdid — Kiểm tra độ nhạy DID',
  'ddml — Kiểm soát chiều cao',
  'rdrobust — Quy trình RD đầy đủ',
];

const stataComparisons = [
  'reg vs. SE vững', 'FE vs. RE', 'FE vs. xtabond2',
  'ivregress vs. ivreg2', 'DID đơn vs. csdid',
  'csdid vs. drdid', 'pdslasso vs. ddml',
  'rdrobust vs. rdlocrand', 'psmatch2 vs. rdrobust',
  'outreg2 vs. estout', 'reghdfe vs. xtreg',
  'boottest vs. cluster SE',
];

// ─── R DATA ─────────────────────────────────────────────────────────────────
const rPackages = [
  { label: 'dplyr / tidyr',      tag: 'Thao tác dữ liệu',  note: 'Tidyverse — chuẩn vàng thao tác dữ liệu' },
  { label: 'ggplot2',             tag: 'Đồ họa',             note: 'Grammar of Graphics — trực quan hóa mạnh mẽ nhất' },
  { label: 'fixest',              tag: 'FE & IV nhanh',      note: 'Ước lượng FE và IV tốc độ cao cho dữ liệu lớn' },
  { label: 'plm',                 tag: 'Dữ liệu bảng',       note: 'Mô hình bảng tuyến tính chuẩn R' },
  { label: 'glmnet',              tag: 'Lasso & Ridge',       note: 'Chính quy hóa và lựa chọn biến chiều cao' },
  { label: 'MatchIt',             tag: 'Ghép cặp',            note: 'Nhiều thuật toán matching cho suy luận nhân quả' },
  { label: 'DeclareDesign',       tag: 'Thiết kế nghiên cứu', note: 'Thiết kế và mô phỏng nghiên cứu ngẫu nhiên' },
  { label: 'broom',               tag: 'Dọn dẹp kết quả',    note: 'Chuyển kết quả mô hình thành tidy data frame' },
  { label: 'gt / gtExtras',       tag: 'Bảng đẹp',            note: 'Tạo bảng xuất bản chất lượng cao trong R' },
  { label: 'DoubleML',            tag: 'Double ML',            note: 'Double/Debiased ML chuẩn Chernozhukov et al. 2018' },
];

const rMistakes = [
  { text: 'Trộn base R và tidyverse — dùng [ ] thay vì filter() / select()', sev: 'Trung bình',   dot: 'yellow' },
  { text: 'summary(lm()) không đủ — cần robust SE qua sandwich package',      sev: 'Nghiêm trọng', dot: 'red' },
  { text: 'Data leakage: transform trước khi chia train/test',                 sev: 'Nghiêm trọng', dot: 'red' },
  { text: 'glmnet mà không cross-validate lambda — overfitting nghiêm trọng',sev: 'Nghiêm trọng', dot: 'red' },
  { text: 'Mean imputation cho missing mà không báo cáo N missing',            sev: 'Nghiêm trọng', dot: 'red' },
];

// ─── SPSS DATA ────────────────────────────────────────────────────────────────
const spssProcedures = [
  { label: 'REGRESSION',           tag: 'OLS cơ bản',          note: 'Hồi quy tuyến tính đa biến' },
  { label: 'LOGISTIC REGRESSION', tag: 'Mô hình nhị phân',     note: 'Mô hình hồi quy logistic' },
  { label: 'MIXED',               tag: 'Linear Mixed Models',  note: 'Mô hình hỗn hợp tuyến tính' },
  { label: 'GENLINMIXED',         tag: 'Mô hình hỗn hợp',       note: 'Mô hình hỗn hợp tổng quát' },
  { label: 'FACTOR',              tag: 'Phân tích nhân tố',     note: 'EFA và CFA cho thang đo' },
  { label: 'CLUSTER',             tag: 'Phân cụm K-means',      note: 'Phân cụm phân cấp và K-means' },
  { label: 'RELIABILITY',          tag: 'Độ tin cậy thang đo',  note: 'Cronbach alpha và phân tích mục' },
  { label: 'ROC',                 tag: 'Đường cong ROC',        note: 'Đánh giá phân loại và AUC' },
  { label: 'EXAMINE',             tag: 'Kiểm tra phân phối',    note: 'Thống kê mô tả và kiểm tra phân phối chuẩn' },
  { label: 'CROSSTABS',            tag: 'Kiểm định độc lập',    note: 'Bảng chéo và chi-square' },
];

const spssMistakes = [
  { text: 'Click-and-run thay vì dùng Syntax — không tái lập được',             sev: 'Nghiêm trọng', dot: 'red' },
  { text: 'Xóa outlier bằng mắt thay vì quy tắc thống kê',                      sev: 'Nghiêm trọng', dot: 'red' },
  { text: 'Diễn giải hệ số logistic là tác động biên — dùng ODDS RATIO',        sev: 'Nghiêm trọng', dot: 'red' },
  { text: 'Missing > 5% mà không xử lý — listwise deletion mặc định',           sev: 'Nghiêm trọng', dot: 'red' },
  { text: 'EFA rồi CFA trên cùng mẫu — cross-validation',                       sev: 'Trung bình',   dot: 'yellow' },
];

// ─── PLS-SEM DATA ───────────────────────────────────────────────────────────
const plsSoftware = [
  { label: 'SmartPLS 4',   tag: 'Phần mềm chuẩn PLS',      note: 'Giao diện chuẩn ngành — tiêu chuẩn thực hành' },
  { label: 'semPLS',        tag: 'PLS-SEM trong R',          note: 'Triển khai PLS-SEM bằng R' },
  { label: 'plsdebias',     tag: 'Hiệu chỉnh chệch',         note: 'Hiệu chỉnh độ chệch trong R' },
  { label: 'matrixB',       tag: 'Bootstrap đa nhóm',         note: 'Đánh giá Bootstrap cho so sánh nhóm' },
  { label: 'PLSpredict',   tag: 'Đánh giá dự báo',           note: 'Đánh giá khả năng dự báo của mô hình' },
  { label: 'IPMA',          tag: 'Importance-Performance',    note: 'Phân tích tầm quan trọng - hiệu suất' },
  { label: 'HTMT',          tag: 'Kiểm định phân biệt',       note: 'Heterotrait-Monotrait cho discriminant validity' },
  { label: 'G*Power',       tag: 'Phân tích công suất',      note: 'Tính cỡ mẫu cho PLS-SEM' },
];

const plsMistakes = [
  { text: 'Dùng PLS-SEM cho mục tiêu giải thích thay vì CB-SEM',                sev: 'Tới hạn',     dot: 'red' },
  { text: 'Không đánh giá mô hình đo lường trước mô hình cấu trúc',            sev: 'Nghiêm trọng', dot: 'red' },
  { text: 'Formative constructs không kiểm tra VIF và trọng số',                 sev: 'Tới hạn',     dot: 'red' },
  { text: 'Mẫu quá nhỏ (n < 10× số chỉ tiêu của khối lớn nhất)',               sev: 'Tới hạn',     dot: 'red' },
  { text: 'Bootstrap < 5000 mà không báo cáo',                                   sev: 'Trung bình',   dot: 'yellow' },
  { text: 'Bỏ qua đánh giá dự báo (PLSpredict / Q²)',                           sev: 'Nghiêm trọng', dot: 'red' },
];

const levelBadgeCls = (level: string) => {
  if (level === 'Cơ bản')    return 'text-green-400 bg-green-500/10 border-green-500/20';
  if (level === 'Trung cấp') return 'text-yellow-400 bg-yellow-500/10 border-yellow-500/20';
  return 'text-red-400 bg-red-500/10 border-red-500/20';
};

const sevBadgeCls = (sev: string, dot: string) => {
  if (dot === 'red')   return 'text-red-400 bg-red-500/10 border-red-500/20';
  return 'text-yellow-400 bg-yellow-500/10 border-yellow-500/20';
};
---

<Layout>
  <!-- ═══════════════════════════════════════════════════════════════
       HERO — Tabbed hero: Stata / R / SPSS / PLS-SEM + right summary card
  ═══════════════════════════════════════════════════════════════ -->
  <section class="flex min-h-screen items-center px-4 py-8 sm:px-6 lg:px-10">
    <div class="mx-auto grid w-full max-w-6xl gap-8 lg:grid-cols-feature lg:items-center">

      <!-- ── Left: Hero + Tab Switcher ── -->
      <div class="space-y-5">

        <!-- Bordered pill badge -->
        <span class="inline-flex items-center gap-1.5 rounded-md border border-orange-500/20 bg-orange-500/10 px-4 py-1.5 text-xs font-medium text-orange-400 shadow-xs w-fit">
          <span class="relative flex h-1.5 w-1.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-orange-500"></span>
          </span>
          Public Beta · {sourceCategories.length} Danh mục · {totalCmdCount}+ Lệnh
        </span>

        <!-- Bold heading -->
        <h1 class="text-balance text-3xl font-black tracking-tight sm:text-5xl leading-[1.1]">
          Cổng tính toán<br/>
          <span class="bg-gradient-to-r from-orange-400 via-amber-300 to-orange-400 bg-clip-text text-transparent">
            Thống kê & Kinh tế lượng
          </span><br/>
          Thống nhất
        </h1>

        <!-- Sub text -->
        <p class="max-w-2xl text-base text-[#a1a1a1] sm:text-lg leading-relaxed">
          Hướng dẫn thực hành tập trung vào
          <span class="text-white font-medium">Stata</span>,
          <span class="text-white font-medium">R</span>,
          <span class="text-white font-medium">SPSS</span> và
          <span class="text-white font-medium">PLS-SEM</span>.
          Nên dùng lệnh nào? Hiểu sự đánh đổi — điều hướng tự tin.
        </p>

        <!-- ── SOFTWARE TAB SWITCHER ── -->
        <div class="space-y-3">
          <!-- Tab bar -->
          <div
            id="explore"
            class="relative inline-flex items-center rounded-xl border border-[#2a2a2a] bg-[#111111] p-1 gap-0.5 shadow-sm"
            style="scroll-margin-top:4rem;">
            <!-- Sliding indicator -->
            <div id="tab-indicator"
              class="absolute top-1 bottom-1 rounded-lg transition-all duration-300 ease-out"
              style="width: calc(25% - 3px); left: 3px; background: rgba(249,115,22,0.15); border: 1px solid rgba(249,115,22,0.3); box-shadow: 0 0 16px rgba(249,115,22,0.2);">
            </div>
            {tabs.map((tab, i) => (
              <button
                data-tab={tab.id}
                data-index={i}
                class="relative z-10 flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 whitespace-nowrap cursor-pointer min-w-[72px] justify-center"
                aria-selected={i === 0 ? 'true' : 'false'}>
                <span
                  class={`tab-icon-${tab.id} inline-flex h-5 w-5 items-center justify-center rounded text-[10px] font-bold font-mono transition-all duration-200 ${
                    i === 0
                      ? tab.color === 'orange' ? 'bg-orange-500/20 text-orange-300'
                      : tab.color === 'amber'  ? 'bg-amber-500/20 text-amber-300'
                      : tab.color === 'yellow'? 'bg-yellow-500/20 text-yellow-300'
                      : 'bg-lime-500/20 text-lime-300'
                      : 'bg-white/5 text-[#666]'
                  }`}
                >
                  {tab.icon}
                </span>
                <span class={`tab-label-${tab.id} ${i === 0 ? 'text-white' : 'text-[#888]'}`}>
                  {tab.label}
                </span>
              </button>
            ))}
          </div>

          <!-- Tab description -->
          <p id="tab-description" class="text-sm text-[#888]">
            {tabs[0].desc}
          </p>

          <!-- CTA row -->
          <div class="flex flex-wrap items-center gap-3">
            <a href="#panel-stata"
              class="group inline-flex items-center gap-2 rounded-md bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-orange-400 transition-all duration-200">
              Khám phá ngay
              <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="https://github.com" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-md border border-[#2a2a2a] bg-[#111111] px-4 py-2.5 text-sm font-medium text-[#888] hover:text-white hover:border-[#3a3a3a] transition-all duration-200">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              GitHub
            </a>
          </div>

          <!-- Language toggle -->
          <div class="inline-flex items-center gap-1 rounded-xl border border-[#2a2a2a] bg-[#111111] p-1 shadow-xs">
            <button id="lang-en"
              class="flex items-center gap-1.5 rounded-md bg-orange-500 text-white px-3 py-1.5 text-sm font-medium min-w-24 justify-center cursor-pointer transition-all duration-200 hover:bg-orange-400">
              English
            </button>
            <button id="lang-vi"
              class="flex items-center gap-1.5 rounded-md px-3 py-1.5 text-sm font-medium text-[#666] min-w-24 justify-center cursor-pointer transition-all duration-200 hover:bg-[#1a1a1a] hover:text-[#a1a1a1]">
              Tiếng Việt
            </button>
          </div>
        </div>
      </div>

      <!-- ── Right: Dynamic summary card per tab ── -->
      <div class="space-y-3">
        <!-- Stata card (default) -->
        <div id="card-stata" class="tab-card rounded-2xl border border-[#2a2a2a] bg-[#111111] p-5 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-orange-400">Stata</p>
            <span class="rounded border border-orange-500/20 bg-orange-500/10 px-2 py-0.5 text-[10px] font-mono text-orange-300">{sourceCategories.length} Danh mục</span>
          </div>
          <p class="text-3xl font-black tracking-tight text-white leading-tight">
            {totalCmdCount}+ Lệnh chuẩn
          </p>
          <p class="mt-2 text-sm text-[#a1a1a1]">
            Từ OLS cơ bản đến <span class="text-white font-medium">Double ML</span>
          </p>
          <div class="mt-4 space-y-1.5">
            {['reg · robust · estout', 'csdid · rdrobust · ddml', 'ivreg2 · reghdfe · honestdid'].map((s) => (
              <div class="flex items-center gap-2 text-xs text-[#666]">
                <span class="h-px flex-1 bg-[#2a2a2a]"></span>
                <span class="font-mono">{s}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- R card -->
        <div id="card-r" class="tab-card hidden rounded-2xl border border-[#2a2a2a] bg-[#111111] p-5 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-amber-400">R</p>
            <span class="rounded border border-amber-500/20 bg-amber-500/10 px-2 py-0.5 text-[10px] font-mono text-amber-300">Tidyverse Ecosystem</span>
          </div>
          <p class="text-3xl font-black tracking-tight text-white leading-tight">
            10 Gói tốt nhất
          </p>
          <p class="mt-2 text-sm text-[#a1a1a1]">
            Từ dplyr đến <span class="text-white font-medium">DoubleML</span>
          </p>
          <div class="mt-4 space-y-1.5">
            {['dplyr · tidyr · ggplot2', 'fixest · plm · glmnet', 'MatchIt · DeclareDesign · gt'].map((s) => (
              <div class="flex items-center gap-2 text-xs text-[#666]">
                <span class="h-px flex-1 bg-[#2a2a2a]"></span>
                <span class="font-mono">{s}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- SPSS card -->
        <div id="card-spss" class="tab-card hidden rounded-2xl border border-[#2a2a2a] bg-[#111111] p-5 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-yellow-400">SPSS</p>
            <span class="rounded border border-yellow-500/20 bg-yellow-500/10 px-2 py-0.5 text-[10px] font-mono text-yellow-300">10 Thủ tục Syntax</span>
          </div>
          <p class="text-3xl font-black tracking-tight text-white leading-tight">
            Syntax chuẩn ngành
          </p>
          <p class="mt-2 text-sm text-[#a1a1a1]">
            Từ REGRESSION đến <span class="text-white font-medium">GENLINMIXED</span>
          </p>
          <div class="mt-4 space-y-1.5">
            {['REGRESSION · LOGISTIC REGR', 'MIXED · GENLINMIXED', 'FACTOR · CLUSTER · ROC'].map((s) => (
              <div class="flex items-center gap-2 text-xs text-[#666]">
                <span class="h-px flex-1 bg-[#2a2a2a]"></span>
                <span class="font-mono">{s}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- PLS-SEM card -->
        <div id="card-pls" class="tab-card hidden rounded-2xl border border-[#2a2a2a] bg-[#111111] p-5 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-lime-400">PLS-SEM</p>
            <span class="rounded border border-lime-500/20 bg-lime-500/10 px-2 py-0.5 text-[10px] font-mono text-lime-300">8 Công cụ tiêu chuẩn</span>
          </div>
          <p class="text-3xl font-black tracking-tight text-white leading-tight">
            Tiêu chuẩn ngành
          </p>
          <p class="mt-2 text-sm text-[#a1a1a1]">
            SmartPLS 4 · <span class="text-white font-medium">PLSpredict</span> · HTMT
