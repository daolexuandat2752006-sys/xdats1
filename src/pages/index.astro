        items: [
          { label: 'Dùng PLS-SEM cho mục tiêu giải thích/lý thuyết thay vì CB-SEM', severity: 'Tới hạn', tagColor: 'bg-red-500/10 text-red-300 border-red-500/20' },
          { label: 'Không đánh giá mô hình đo lường trước mô hình cấu trúc', severity: 'Nghiêm trọng', tagColor: 'bg-orange-500/10 text-orange-300 border-orange-500/20' },
          { label: 'Báo cáo chỉ R² mà không đánh giá convergent validity', severity: 'Nghiêm trọng', tagColor: 'bg-orange-500/10 text-orange-300 border-orange-500/20' },
          { label: 'Đánh giá reflective constructs bằng VIF (thay vì HTMT)', severity: 'Nghiêm trọng', tagColor: 'bg-orange-500/10 text-orange-300 border-orange-500/20' },
          { label: 'Formative constructs không kiểm tra VIF và trọng số', severity: 'Tới hạn', tagColor: 'bg-red-500/10 text-red-300 border-red-500/20' },
