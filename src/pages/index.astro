      label: string;
      tag?: string;
      severity?: 'Tới hạn' | 'Nghiêm trọng' | 'Trung bình' | 'Cơ bản' | 'Nâng cao';
      tagColor?: string;
    }>;
  }>;
}> = {

  // ═══════════════════ STATA ═══════════════════
  stata: {
    sections: [
      {
        id: 'best-packages',
        title: 'Gói lệnh tốt nhất',
        titleEn: 'Best Packages',
