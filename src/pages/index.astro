  <!-- Floating scroll indicator -->
  <div class="fixed right-4 top-20 flex items-center gap-2 rounded-md border border-[#2a2a2a] bg-[#0a0a0a]/90 px-3 py-1.5 text-xs text-[#555] shadow-sm backdrop-blur-sm z-20">
