          { label: 'Các khái niệm là phản chiếu hay hình thành?', tag: 'Bước 2', tagColor: 'bg-slate-500/10 text-slate-300 border-slate-500/20' },
          { label: 'Đánh giá mô hình đo lường trước', tag: 'Bước 3', tagColor: 'bg-lime-500/10 text-lime-300 border-lime-500/20' },
          { label: 'Đánh giá mô hình cấu trúc sau', tag: 'Bước 4', tagColor: 'bg-lime-500/10 text-lime-300 border-lime-500/20' },
